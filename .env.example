# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gocrm
DB_USER=root
DB_PASSWORD=
DB_SSL_MODE=disable

# Server Configuration
SERVER_PORT=8080
SERVER_MODE=development

# JWT Configuration
# CRITICAL: JWT_SECRET must be:
#  - At least 32 characters long
#  - Unique and random
#  - Never committed to version control
# Generate a secure secret with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS_LONG
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# API Configuration
API_PREFIX=/api/v1